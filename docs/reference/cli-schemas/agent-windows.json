{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://testanyware.dev/schemas/agent-windows.json",
  "title": "agent-windows",
  "description": "Output of `testanyware agent windows --json`. Identical wire shape to agent-snapshot but the `elements` field is omitted from each window.",
  "type": "object",
  "required": ["schema_version", "ok", "windows"],
  "properties": {
    "schema_version": { "type": "string" },
    "ok": { "type": "boolean" },
    "windows": {
      "type": "array",
      "items": { "$ref": "#/$defs/window" }
    }
  },
  "$defs": {
    "window": {
      "type": "object",
      "required": [
        "windowType",
        "sizeWidth",
        "sizeHeight",
        "positionX",
        "positionY",
        "appName",
        "focused"
      ],
      "properties": {
        "title": { "type": "string" },
        "windowType": { "type": "string" },
        "sizeWidth": { "type": "number" },
        "sizeHeight": { "type": "number" },
        "positionX": { "type": "number" },
        "positionY": { "type": "number" },
        "appName": { "type": "string" },
        "focused": { "type": "boolean" }
      }
    }
  }
}
