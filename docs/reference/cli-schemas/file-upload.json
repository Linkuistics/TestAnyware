{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://testanyware.dev/schemas/file-upload.json",
  "title": "file-upload",
  "description": "Output of `testanyware file upload --json`. Confirmation receipt for a host→guest file transfer.",
  "type": "object",
  "required": ["schema_version", "ok"],
  "properties": {
    "schema_version": { "type": "string" },
    "ok": { "type": "boolean" },
    "local": { "type": "string" },
    "remote": { "type": "string" },
    "bytes": { "type": "integer" },
    "dry_run": { "type": "boolean" }
  }
}
