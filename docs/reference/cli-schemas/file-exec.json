{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://testanyware.dev/schemas/file-exec.json",
  "title": "file-exec",
  "description": "Output of `testanyware file exec --json`. The binary itself exits 0 on a clean spawn; the in-VM exit is in `exit_code`.",
  "type": "object",
  "required": ["schema_version", "ok"],
  "properties": {
    "schema_version": { "type": "string" },
    "ok": { "type": "boolean" },
    "command": { "type": "string" },
    "exit_code": { "type": "integer" },
    "stdout": { "type": "string" },
    "stderr": { "type": "string" },
    "timed_out": { "type": "boolean" },
    "dry_run": { "type": "boolean" },
    "timeout": { "type": "integer" },
    "detach": { "type": "boolean" }
  }
}
